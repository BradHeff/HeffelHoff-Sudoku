# =====================================================================
# HeffelHoff Sudoku — .gitignore
# =====================================================================

# ---- Secrets / env (NEVER commit) ----
.env
.env.*
!.env.example
!.env.claude.md
.envrc
.envrc.local
**/secrets/

# Signing material (iOS + Android)
*.pem
*.p8
*.p12
*.cer
*.mobileprovision
*.keystore
*.jks
*.pkcs12
android/key.properties
android/app/upload-keystore.jks
android/app/release-keystore.jks
android/app/keystore.properties

# Firebase / Google service configs (have OAuth client IDs)
**/google-services.json
**/GoogleService-Info.plist
**/firebase_options.dart
**/firebase_app_id_file.json

# Service-account JSON keys (Google Play receipt verification, Firebase admin, etc.)
*service_account*.json
*service-account*.json
*-credentials.json
playstore-key.json
google-play-key.json

# Supabase
supabase/.env
supabase/.env.*
supabase/.temp/
supabase/.branches/

# Apple App Store Connect API keys
AuthKey_*.p8

# Generic AI / IDE chat & history (in case you use these on a machine that
# clones this repo, don't leak the conversation log)
.aider*
.cursor/
.continue/
.codeium/
.claude/
.kilocode/
.windsurf/

# ---- Flutter / Dart ----
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
**/build/
*.dart_tool
**/generated_plugin_registrant.dart
**/.fvm/
.fvmrc

# Dart code generation outputs (regenerated by build_runner; some teams
# commit these — we don't, to keep diffs clean).
**/*.g.dart
**/*.freezed.dart
**/*.gr.dart
**/*.config.dart
# Drift exception: keep its generated schema if hand-edited later
!**/database.g.dart

# Coverage
coverage/
.lcov
lcov.info
**/lcov.info

# Test outputs
test/.test_coverage.dart

# Python (tools/synth_sounds.py)
__pycache__/
*.pyc
*.pyo
.Python
venv/
.venv/

# ---- iOS ----
ios/Flutter/Flutter.framework/
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/app.flx
ios/Flutter/app.zip
ios/Flutter/flutter_assets/
ios/Flutter/flutter_export_environment.sh
ios/ServiceDefinitions.json
ios/Runner/GeneratedPluginRegistrant.*
ios/Pods/
ios/Podfile.lock
ios/.symlinks/
**/DerivedData/
**/xcuserdata/
*.xcuserstate
*.xcworkspace/xcuserdata/

# ---- Android ----
android/.gradle/
android/captures/
android/gradlew
android/gradlew.bat
android/local.properties
android/**/GeneratedPluginRegistrant.java
android/app/release/
android/app/debug/
android/app/profile/
*.iml
*.ipr
*.iws

# Build outputs at any path (in case someone copies an apk/aab/ipa
# out of build/ into the tree to share)
*.apk
*.aab
*.ipa
*.app
*.dSYM.zip
*.dSYM

# ---- IDE ----
.idea/
.vscode/
!.vscode/launch.json
!.vscode/settings.shared.json
*.swp
*.swo
*.swn
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Supabase Edge Functions (Deno) ----
supabase/functions/**/node_modules/
supabase/functions/**/dist/

# ---- Misc ----
*.tmp
*.bak
.history/

# ---- Local reference / inspiration material (not in repo) ----
Screenshots/
