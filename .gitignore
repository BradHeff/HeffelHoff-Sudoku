# =====================================================================
# HeffelHoff Sudoku — .gitignore
# =====================================================================

# ---- Secrets / env (NEVER commit) ----
.env
.env.*
!.env.example
!.env.claude.md
**/secrets/
*.pem
*.p8
*.keystore
*.jks
android/key.properties
android/app/upload-keystore.jks
ios/Runner/GoogleService-Info.plist
android/app/google-services.json
supabase/.env
supabase/.env.*
supabase/.temp/

# ---- Flutter / Dart ----
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
**/build/
*.dart_tool
**/generated_plugin_registrant.dart
**/.fvm/
.fvmrc

# Dart code generation outputs (regenerated by build_runner; some teams
# commit these — we don't, to keep diffs clean).
**/*.g.dart
**/*.freezed.dart
**/*.gr.dart
**/*.config.dart
# Drift exception: keep its generated schema if hand-edited later
!**/database.g.dart

# Coverage
coverage/
.lcov

# Test outputs
test/.test_coverage.dart

# ---- iOS ----
ios/Flutter/Flutter.framework/
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/app.flx
ios/Flutter/app.zip
ios/Flutter/flutter_assets/
ios/Flutter/flutter_export_environment.sh
ios/ServiceDefinitions.json
ios/Runner/GeneratedPluginRegistrant.*
ios/Pods/
ios/Podfile.lock
ios/.symlinks/
**/DerivedData/
**/xcuserdata/
*.xcuserstate
*.xcworkspace/xcuserdata/

# ---- Android ----
android/.gradle/
android/captures/
android/gradlew
android/gradlew.bat
android/local.properties
android/**/GeneratedPluginRegistrant.java
android/app/release/
android/app/debug/
android/app/profile/
*.iml
*.ipr
*.iws

# ---- IDE ----
.idea/
.vscode/
!.vscode/launch.json
!.vscode/settings.shared.json
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Supabase Edge Functions (Deno) ----
supabase/functions/**/node_modules/
supabase/functions/**/dist/

# ---- Misc ----
*.tmp
*.bak
.history/

# ---- Local reference / inspiration material (not in repo) ----
Screenshots/
